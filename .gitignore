# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro
*.local

# Env files (broader catch — covers .env.production.local, .env.staging, etc.)
.env
.env.*
!.env.example

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Playwright MCP local artifacts (console logs + page snapshots)
.playwright-mcp/

# Supabase CLI local cache (regenerated on `supabase link`)
supabase/.temp/
supabase/.branches/

# AI assistant instructions and local state (private to local clone)
CLAUDE.md
.claude/

# Session working memos (per-session logs, never committed)
session.md
session-*.md
SESSION_*.md
handoff.md
backlog.md

# Docs directory: only tracked docs are whitelisted below.
# Everything else (roadmaps, session state, scratch notes) stays local.
docs/*
!docs/API.md
!docs/ARCHITECTURE.md
!docs/PRODUCT.md
!docs/SCALABILITY.md
!docs/UI-UX.md
!docs/DESIGN-SYSTEM.md

